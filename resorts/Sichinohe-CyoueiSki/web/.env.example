# 本番・ステージングの絶対URL（OGP・canonical 等で利用する場合）
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Mapbox GL JS（/map 3D地形マップ・アクセス背景のフォールバック）
# https://account.mapbox.com/
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=YOUR_API_KEY

# Google Maps（/access 背景 — Cloud-based Map Styling の Map ID）
# https://console.cloud.google.com/google/maps-apis/studio/maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_API_KEY
# NEXT_PUBLIC_GOOGLE_MAP_ID=YOUR_MAP_ID

# 管理更新API保護トークン（/api/admin/* 用）— Vercel 本番で必須
# ADMIN_UPDATE_TOKEN=replace-this-with-a-strong-random-string

# 本番で /admin UI を開く（未設定時は production で 404）
# ADMIN_PAGE_ENABLED=true

# Vercel Blob — 任意。未設定 or デプロイ済み status.json あり時は Git の data/map/status.json を公開。
# admin からの一時保存用（本番表示は Git push → 再デプロイが正）。
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
